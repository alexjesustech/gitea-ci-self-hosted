# =================================================================
# MODELO DE CONFIGURAÇÕES LOCAIS DO GITEA
# =================================================================
# Copie este arquivo para .env e ajuste as configurações
# cp .env.example .env

# --- CONFIGURAÇÕES DO DOCKER ---
GITEA_VERSION=1.24.5
COMPOSE_PROJECT_NAME=gitea

# --- CONFIGURAÇÕES DE REDE ---
HOST_PORT_WEB=3000
HOST_PORT_SSH=2222

# --- CONFIGURAÇÕES DO AMBIENTE ---
TZ=America/Porto_Velho

# IDs do usuário do sistema host (use 'id' para descobrir)
USER_UID=1000
USER_GID=1000

# --- CONFIGURAÇÕES DE DOMÍNIO ---
GITEA_DOMAIN=localhost
GITEA_ROOT_URL=http://localhost:3000

# --- CONFIGURAÇÕES DE BACKUP ---
BACKUP_SCHEDULE=0 2 * * *
BACKUP_MAX_FILES=7

# --- CONFIGURAÇÕES DE SEGURANÇA ---
# Chave secreta (gere uma nova: openssl rand -hex 32)
GITEA_SECRET_KEY=SUBSTITUA-POR-UMA-CHAVE-SECRETA-REAL
# JWT Secret (gere uma nova: openssl rand -hex 32)
GITEA_JWT_SECRET=SUBSTITUA-POR-UMA-CHAVE-JWT-REAL

# --- CONFIGURAÇÕES DE EMAIL (Opcional) ---
# GITEA_MAILER_ENABLED=false
# GITEA_MAILER_HOST=smtp.exemplo.com
# GITEA_MAILER_PORT=587
# GITEA_MAILER_USER=usuario@exemplo.com
# GITEA_MAILER_PASSWORD=senha-segura

# --- CONFIGURAÇÕES DE PERFORMANCE ---
GITEA_MEMORY_LIMIT=512m
GITEA_CPU_LIMIT=1.0